generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum ProductCondition {
  LIKE_NEW
  EXCELLENT
  GOOD
  FAIR
}

enum TrustBadge {
  TRUSTED_SELLER
  TOP_SELLER
  ELITE_SELLER
}

enum OrderStatus {
  PLACED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
  ARCHIVED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  phone         String?
  avatarUrl     String?
  role          Role           @default(BUYER)
  isActive      Boolean        @default(true)
  isBanned      Boolean        @default(false)
  bannedReason  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sellerProfile SellerProfile?
  buyerProfile  BuyerProfile?
  orders        Order[]        @relation("BuyerOrders")
  reviews       Review[]       @relation("ReviewAuthor")
  wishlist      WishlistItem[]
  cart          CartItem[]
  adminLogs     AdminLog[]
  disputes      Dispute[]      @relation("DisputeBuyer")
  @@map("users")
}

model SellerProfile {
  id            String            @id @default(cuid())
  userId        String            @unique
  user          User              @relation(fields: [userId], references: [id])
  shopName      String
  bio           String?
  location      String?
  avatarUrl     String?
  coverImageUrl String?
  isVerified    Boolean           @default(false)
  trustBadge    TrustBadge?
  totalSales    Int               @default(0)
  totalRevenue  Float             @default(0)
  averageRating Float             @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  commitment    Commitment?
  trustScore    SellerTrustScore?
  products      Product[]
  sellerOrders  OrderItem[]       @relation("SellerOrderItems")
  @@map("seller_profiles")
}

model BuyerProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  address    String?
  city       String?
  postalCode String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@map("buyer_profiles")
}

model Commitment {
  id              String        @id @default(cuid())
  sellerProfileId String        @unique
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id])
  pledgeText      String        @db.Text
  agreedToTerms   Boolean       @default(false)
  signedAt        DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@map("commitments")
}

model SellerTrustScore {
  id                 String        @id @default(cuid())
  sellerProfileId    String        @unique
  sellerProfile      SellerProfile @relation(fields: [sellerProfileId], references: [id])
  score              Float         @default(0)
  accuracyScore      Float         @default(0)
  shippingScore      Float         @default(0)
  communicationScore Float         @default(0)
  totalReviews       Int           @default(0)
  updatedAt          DateTime      @updatedAt
  @@map("seller_trust_scores")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  products    Product[]
  @@map("categories")
}

model Product {
  id               String           @id @default(cuid())
  sellerProfileId  String
  sellerProfile    SellerProfile    @relation(fields: [sellerProfileId], references: [id])
  categoryId       String
  category         Category         @relation(fields: [categoryId], references: [id])
  title            String
  description      String           @db.Text
  condition        ProductCondition
  originalPrice    Float
  sellingPrice     Float
  defectDisclosure String           @db.Text
  brand            String?
  size             String?
  color            String?
  tags             String[]
  imageUrls        String[]
  videoUrl         String?
  cloudinaryIds    String[]
  status           ProductStatus    @default(PENDING)
  isFeatured       Boolean          @default(false)
  viewCount        Int              @default(0)
  wishlistCount    Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  orderItems       OrderItem[]
  reviews          Review[]
  wishlistItems    WishlistItem[]
  cartItems        CartItem[]
  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  buyerId         String
  buyer           User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  totalAmount     Float
  status          OrderStatus @default(PLACED)
  paymentMethod   String      @default("esewa")
  paymentStatus   String      @default("pending")
  esewaRefId      String?
  shippingAddress String
  shippingCity    String
  trackingCode    String?
  notes           String?
  placedAt        DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
  disputes        Dispute[]
  @@map("orders")
}

model OrderItem {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  sellerProfileId String
  sellerProfile   SellerProfile @relation("SellerOrderItems", fields: [sellerProfileId], references: [id])
  price           Float
  quantity        Int           @default(1)
  status          OrderStatus   @default(PLACED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@map("order_items")
}

model Review {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  authorId       String
  author         User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  rating         Int
  title          String?
  body           String   @db.Text
  accuracyRating Int?
  shippingRating Int?
  images         String[]
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@map("reviews")
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  @@unique([userId, productId])
  @@map("wishlist_items")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, productId])
  @@map("cart_items")
}

model Dispute {
  id         String        @id @default(cuid())
  orderId    String
  order      Order         @relation(fields: [orderId], references: [id])
  buyerId    String
  buyer      User          @relation("DisputeBuyer", fields: [buyerId], references: [id])
  reason     String        @db.Text
  evidence   String[]
  status     DisputeStatus @default(OPEN)
  resolution String?       @db.Text
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  @@map("disputes")
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  action    String
  target    String?
  targetId  String?
  details   Json?
  createdAt DateTime @default(now())
  @@map("admin_logs")
}
